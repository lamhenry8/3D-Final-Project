# Define macros (only works in top-level gitattributes files)
[attr]lfs               filter=lfs diff=lfs merge=lfs -text
[attr]unity-json        eol=lf linguist-language=json
[attr]unity-yaml        merge=unityyamlmerge eol=lf linguist-language=yaml

# This project's Editor Settings use Force Binary asset serialization
# (ProjectSettings/EditorSettings.asset: m_SerializationMode: 2), so the
# extensions below are native binary-serialized files, not YAML text.
# Applying eol=lf normalization to them silently strips \r bytes from
# \r\n byte pairs inside the binary payload and corrupts the asset
# (this is what happened to Assets/New Terrain.asset).
[attr]unity-serialized  -text merge=unityyamlmerge linguist-language=yaml

# Optionally collapse Unity YAML files on GitHub diffs
# [attr]unity-yaml        merge=unityyamlmerge text linguist-language=yaml linguist-generated

# Unity source files
*.cginc                 text
*.compute               text linguist-language=hlsl
*.cs                    text diff=csharp
*.hlsl                  text linguist-language=hlsl
*.raytrace              text linguist-language=hlsl
*.shader                text

# Unity JSON files
*.asmdef                unity-json
*.asmref                unity-json
*.index                 unity-json
*.inputactions          unity-json
*.shadergraph           unity-json
*.shadersubgraph        unity-json

# Unity UI Toolkit files
*.tss                   text diff=css linguist-language=css
*.uss                   text diff=css linguist-language=css
*.uxml                  text linguist-language=xml linguist-detectable

# Unity YAML files
# NOTE: .meta files are always plain text regardless of the project's
# Asset Serialization mode, so they stay on the text-safe unity-yaml macro.
# Everything else here is a native serialized object and, under this
# project's Force Binary serialization mode, is binary on disk -- so it
# uses the binary-safe unity-serialized macro instead (see above).
*.anim                  unity-serialized
*.asset                 unity-serialized
*.brush                 unity-serialized
*.controller            unity-serialized
*.flare                 unity-serialized
*.fontsettings          unity-serialized
*.giparams              unity-serialized
*.guiskin               unity-serialized
*.lighting              unity-serialized
*.mask                  unity-serialized
*.mat                   unity-serialized
*.meta                  unity-yaml
*.mixer                 unity-serialized
*.overrideController    unity-serialized
*.playable              unity-serialized
*.prefab                unity-serialized
*.preset                unity-serialized
*.renderTexture         unity-serialized
*.scenetemplate         unity-serialized
*.shadervariants        unity-serialized
*.signal                unity-serialized
*.spriteatlas           unity-serialized
*.spriteatlasv2         unity-serialized
*.terrainlayer          unity-serialized
*.unity                 unity-serialized

# "physic" for 3D but "physics" for 2D
*.physicMaterial        unity-serialized
*.physicsMaterial2D     unity-serialized

# Exclude from GitHub stats and diffs: third-party plugins, packages lock file
Assets/Plugins/**           linguist-generated
Packages/packages-lock.json linguist-generated

